# GCP
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
USE_VERTEX_AI=false

# Service URLs (local docker-compose defaults)
AI_GATEWAY_URL=http://localhost:8080
RAG_SERVICE_URL=http://localhost:8081
AGENT_SERVICE_URL=http://localhost:8082
JIRA_SERVICE_URL=http://localhost:8083
CONFLUENCE_SERVICE_URL=http://localhost:8084
GITHUB_SERVICE_URL=http://localhost:8085
REPORTING_SERVICE_URL=http://localhost:8086

# Vertex AI
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-005
VECTOR_SEARCH_INDEX_ID=
VECTOR_SEARCH_ENDPOINT_ID=

# Data Layer
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_ai
CLOUD_SQL_INSTANCE=
CLOUD_SQL_DATABASE=enterprise_ai
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=
BIGQUERY_DATASET=enterprise_analytics
GCS_BUCKET=
GCS_RAG_PREFIX=rag-documents

# Integrations
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=
GITHUB_TOKEN=
GITHUB_ORG=your-org

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=enterprise_ai

# Kubernetes
KUBECONFIG_PATH=
KUBERNETES_NAMESPACE=default

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Browser automation
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
BROWSER_CHANNEL=chrome
BROWSER_EXECUTABLE_PATH=

# Local dev
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=enterprise_knowledge
APP_ENV=development

# Frontend
VITE_API_URL=http://localhost:8080
